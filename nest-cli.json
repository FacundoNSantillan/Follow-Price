{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api-core/src",
  "monorepo": true,
  "projects": {
    "ai": {
      "type": "library",
      "root": "libs/ai",
      "entryFile": "index",
      "sourceRoot": "libs/ai/src"
    },
    "api-core": {
      "type": "application",
      "root": "apps/api-core",
      "entryFile": "main", 
      "sourceRoot": "apps/api-core/src"
    },
    "scrapper-service": {
      "type": "application",
      "root": "apps/scrapper-service",
      "entryFile": "main",
      "sourceRoot": "apps/scrapper-service/src"
    }
  },
  "compilerOptions": {
    "webpack": true,
    "manualRestart": true,
    "outputPath": "dist" 
  }
}