datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           String     @id @default(uuid())
  url          String     @unique
  name         String     
  originalName String?    
  category     String?    
  specs        Json?      
  store        String
  image        String?
  prices       PriceLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
}

model PriceLog {
  id        String   @id @default(uuid())
  price     Float
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  createdAt DateTime @default(now())
}